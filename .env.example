# DeepSeek (or any OpenAI-compatible) credentials
DEEPSEEK_API_KEY=sk-replace-me
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Backend
PORT=8000
LOG_LEVEL=INFO

# Path to SQLite session DB. Leave unset to use the in-memory store
# (sessions wiped on restart). Path is relative to the backend cwd, so
# ../cothinker.db lands at the project root and is gitignored. For
# Docker, compose sets this automatically to /data/cothinker.db.
# COTHINKER_DB=../cothinker.db

# CORS allowlist (comma-separated). Defaults to local Vite dev hosts.
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
