# DeepSeek (or any OpenAI-compatible) credentials
DEEPSEEK_API_KEY=sk-replace-me
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Default model — used by thinker (前台 IM 节奏) and rewriter. Co-Thinker
# splits "fast 浮现 / 深度 元认知" across two models per the Harness
# adaptive-thinking design: the fast lane stays flash so the IM rhythm
# isn't broken by reasoning latency. `deepseek-chat` is aliased to
# v4-flash non-thinking mode and will be removed 2026-07-24.
DEEPSEEK_MODEL=deepseek-v4-flash
# Reasoner model — used by judge (元认知 / watching-the-watcher).
# Async metabolize, so seconds-to-minutes latency is acceptable. v4-pro
# is the reasoning tier; override to `deepseek-v4-flash` (cheaper but
# weaker推理) or `deepseek-reasoner` (legacy alias, removed 2026-07-24)
# if needed.
DEEPSEEK_REASONER_MODEL=deepseek-v4-pro

# Backend
PORT=8000
LOG_LEVEL=INFO

# Path to SQLite session DB. Leave unset to use the in-memory store
# (sessions wiped on restart). Path is relative to the backend cwd, so
# ../cothinker.db lands at the project root and is gitignored. For
# Docker, compose sets this automatically to /data/cothinker.db.
# COTHINKER_DB=../cothinker.db

# CORS allowlist (comma-separated). Defaults to local Vite dev hosts.
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
